CompileFlags:
  Add:
    - "-std=c++20"
    - "-Isrc"
    - "-Ithird_party/highs-install/include"
    - "-Ithird_party/highs-install/include/highs"
    - "-Ithird_party/fmt-install/include"
  Remove:
    - "-W*"  # 移除所有警告选项，减少干扰

Diagnostics:
  UnusedIncludes: None
  MissingIncludes: None
  ClangTidy:
    Add:
      - modernize-*
      - performance-*
    Remove:
      - modernize-use-trailing-return-type

InlayHints:
  Enabled: Yes
  ParameterNames: Yes
  DeducedTypes: Yes

Hover:
  ShowAKA: Yes
